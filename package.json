{
  "name": "swim-hub",
  "version": "1.0.0",
  "private": true,
  "description": "水泳選手マネジメントシステム - モノレポ",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter @swim-hub/web dev",
    "dev:web": "pnpm --filter @swim-hub/web dev",
    "dev:https": "pnpm --filter @swim-hub/web dev:https",
    "dev:mobile": "pnpm --filter @swim-hub/mobile start:local",
    "dev:mobile:clear": "pnpm --filter @swim-hub/mobile start:clear",
    "dev:mobile:local": "pnpm --filter @swim-hub/mobile start:local",
    "dev:mobile:dev": "pnpm --filter @swim-hub/mobile start:dev",
    "dev:mobile:prod": "pnpm --filter @swim-hub/mobile start:prod",
    "ios": "pnpm --filter @swim-hub/mobile ios:local",
    "ios:clear": "pnpm --filter @swim-hub/mobile ios:clear",
    "ios:local": "pnpm --filter @swim-hub/mobile ios:local",
    "ios:dev": "pnpm --filter @swim-hub/mobile ios:dev",
    "ios:prod": "pnpm --filter @swim-hub/mobile ios:prod",
    "ios:run": "cd apps/mobile && npx dotenvx run -f .env.local -- expo run:ios",
    "ios:run:sim": "cd apps/mobile && npx dotenvx run -f .env.local -- expo run:ios --simulator \"iPhone 16\"",
    "build": "pnpm --filter @swim-hub/web build",
    "build:web": "pnpm --filter @swim-hub/web build",
    "build:mobile:android": "cd apps/mobile && eas build -p android",
    "build:mobile:ios": "cd apps/mobile && eas build -p ios",
    "start": "pnpm --filter @swim-hub/web start",
    "start:web": "pnpm --filter @swim-hub/web start",
    "lint": "pnpm -r --if-present lint",
    "lint:web": "pnpm --filter @swim-hub/web lint",
    "lint:mobile": "pnpm --filter @swim-hub/mobile lint",
    "test": "pnpm --filter @swim-hub/web test && pnpm --filter @swim-hub/mobile test && pnpm --filter @swim-hub/shared test",
    "test:unit": "pnpm --filter @swim-hub/web test && pnpm --filter @swim-hub/shared test",
    "test:watch": "pnpm --filter @swim-hub/web test:watch",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "test:e2e": "pnpm --filter @swim-hub/web test:e2e",
    "test:web": "pnpm --filter @swim-hub/web test",
    "test:web:local": "pnpm --filter @swim-hub/web test:web:local",
    "test:web:remote": "pnpm --filter @swim-hub/web test:web:remote",
    "test:mobile": "pnpm --filter @swim-hub/mobile test",
    "test:mobile:watch": "pnpm --filter @swim-hub/mobile test:watch",
    "test:mobile:coverage": "pnpm --filter @swim-hub/mobile test:coverage",
    "type-check": "pnpm -r --if-present type-check",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules",
    "clean:mobile": "pnpm --filter @swim-hub/mobile clean",
    "install:all": "pnpm install",
    "install:mobile": "pnpm --filter @swim-hub/mobile install",
    "docker:dev": "pnpm --filter @swim-hub/web docker:dev",
    "docker:build": "pnpm --filter @swim-hub/web docker:build",
    "docker:down": "pnpm --filter @swim-hub/web docker:down",
    "supabase:start": "bash supabase/start.sh",
    "supabase:stop": "npx supabase stop --workdir supabase",
    "supabase:reset": "npx supabase db reset --workdir supabase",
    "supabase:status": "npx supabase status --workdir supabase",
    "db:dump-prod": "bash supabase/scripts/dump-prod.sh",
    "db:reset": "bash supabase/scripts/reset-local.sh",
    "db:reset:no-seed": "bash supabase/scripts/reset-local.sh --no-seed",
    "android": "cd apps/mobile && expo run:android"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@dotenvx/dotenvx-ext-vault": "^0.3.2",
    "@playwright/test": "^1.56.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25",
    "dotenv": "^17.2.3",
    "enhanced-resolve": "^5.18.4",
    "jsonwebtoken": "^9.0.3",
    "minimatch": "^10.2.1",
    "supabase": "^2.71.1",
    "tapable": "^2.3.0",
    "turbo": "^2.6.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "jsdom": "24.1.3",
      "tar": "^7.5.4",
      "diff": "^5.2.2",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@aws-sdk/client-cloudfront": "^3.750.0",
      "@aws-sdk/client-sts": "^3.750.0",
      "fast-xml-parser": "^5.3.4",
      "minimatch": "^10.2.1",
      "@supabase/supabase-js": "^2.97.0"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/swim-hub.git"
  },
  "keywords": [
    "swimming",
    "management",
    "nextjs",
    "react-native",
    "supabase",
    "monorepo"
  ],
  "author": "開発チーム",
  "license": "MIT",
  "dependencies": {
    "stripe": "^20.4.1"
  }
}
