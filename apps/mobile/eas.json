{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "sdk-55"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_WEB_API_URL": "https://swim-hub.app",
        "EXPO_PUBLIC_R2_PUBLIC_URL": "https://images.swim-hub.app"
      }
    },
    "preview": {
      "channel": "preview",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6756808731",
        "appleId": "ryuuhei.hosoi@gmail.com"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account-key.json"
      }
    }
  }
}
